Cell[CellGroupData[{

Cell["1.3 Elastic rebound theory", "Subsection",ExpressionUUID->"86ee16c3-24b4-49d5-b627-81c07c591fdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "physical", " ", "mechanism", " ", "of", " ", "earthquakes", " ",
    "was", " ", "first", " ", "clearly", " ", "articulated", " ", "by", " ", 
   RowBox[{"H", ".", " ", "F", ".", " ", "Reid"}], " ", "in", " ", "1910"}], ",",
   " ", 
  RowBox[{
  "following", " ", "his", " ", "study", " ", "of", " ", "the", " ", "1906", " ",
    "San", " ", "Francisco", " ", "earthquake", " ", "on", " ", "the", " ", 
   "San", " ", "Andreas", " ", 
   RowBox[{"Fault", ".", " ", 
    RowBox[{"Reid", "'"}]}], "s", " ", "\"\<elastic rebound theory\>\"", " ", 
   
   RowBox[{"states", ":", " ", 
    RowBox[{
    "rock", " ", "on", " ", "either", " ", "side", " ", "of", " ", "a", " ", 
     "locked", " ", "fault", " ", "deforms", " ", "elastically", " ", "under",
      " ", "tectonic", " ", "stress", " ", "until", " ", "the", " ", 
     "accumulated", " ", "shear", " ", "stress", " ", "exceeds", " ", "the", " ",
      "frictional", " ", "strength", " ", "of", " ", "the", " ", "fault", " ", 
     RowBox[{"surface", ".", " ", "At"}], " ", "that", " ", "point"}]}]}], ",",
   " ", 
  RowBox[{"the", " ", "fault", " ", "ruptures", " ", "suddenly"}], ",", " ", 
  RowBox[{
  "and", " ", "the", " ", "rock", " ", "on", " ", "each", " ", "side", " ", 
   "snaps", " ", "back", " ", 
   RowBox[{"(", "\"\<rebounds\>\"", ")"}], " ", "to", " ", "an", " ", 
   "undeformed", " ", 
   RowBox[{"state", ".", " ", "The"}], " ", "elastic", " ", "strain", " ", 
   "energy", " ", "stored", " ", "over", " ", "decades", " ", "is", " ", 
   "released", " ", "in", " ", "seconds", " ", "as", " ", "seismic", " ", 
   "waves", " ", "that", " ", "radiate", " ", "outward", " ", "from", " ", 
   "the", " ", "rupture", " ", 
   RowBox[{"zone", "."}]}]}]], "Text",ExpressionUUID->"2b525815-42f6-4fae-\
bf7c-6e8de601ea41"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1.4 Quantifying earthquakes", "Subsection",ExpressionUUID->"689fa0e5-17b1-4e3e-959d-067ac80c034d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "size", " ", "of", " ", "an", " ", "earthquake", " ", "is", " ",
    "quantified", " ", "by", " ", "the", " ", "seismic", " ", "moment"}], ",",
   " ", 
  RowBox[{
  "a", " ", "physical", " ", "measure", " ", "of", " ", "the", " ", "total", " ", 
   RowBox[{"deformation", ":"}]}]}]], "Text",ExpressionUUID->"7c525144-5e15-\
4742-abdb-ecefdda37c67"],

Cell[BoxData[
 "Seismic Moment:\n" <> $CellContext`StringTrimRight[
  "    M0 = mu * A * d                                           "]], "Text",E\
xpressionUUID->"acae0be7-b35e-4427-ad63-e806a91c9e56"],

Cell[BoxData[
 "where:\n" <> $CellContext`StringTrimRight[
  "    mu = shear modulus of the rock [Pa]                       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "         (typically ~30 GPa for crustal rock,                 "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "          ~70 GPa for upper mantle)                           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    A  = area of the fault rupture surface [m^2]              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    d  = average displacement (slip) across the fault [m]     "]], "Text",E\
xpressionUUID->"f69f68b5-d30c-439c-9f8b-2f9d735780f3"],

Cell[BoxData[
 "Moment Magnitude (Kanamori 1977):\n" <> $CellContext`StringTrimRight[
  "    Mw = (2/3)(Log10[M0] - 9.1)     [M0 in N*m]              "]], "Text",Ex\
pressionUUID->"88b01344-3a5a-4e43-aaa2-3da4f8fa1172"],

Cell[BoxData[
 "Energy-Magnitude Relation (Gutenberg & Richter 1956,\n" <> \
$CellContext`StringTrimRight[
  "  refined by Kanamori 1977):                                  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    Log10[Es] = 1.5 Mw + 4.8        [Es in Joules]           "]], "Text",Ex\
pressionUUID->"1206a333-62a8-407a-ba44-bef91adcd66f"],

Cell[BoxData[
 RowBox[{"The", " ", "moment", " ", "magnitude", " ", "scale", " ", "is", " ", 
  RowBox[{"logarithmic", ":", " ", 
   RowBox[{
   "each", " ", "unit", " ", "increase", " ", "in", " ", "Mw", " ", 
    "corresponds", " ", "to", " ", "a", " ", "factor", " ", "of", " ", 
    RowBox[{"10", "^", 
     RowBox[{"1.5", " ", "~", " ", "31.6"}]}], " ", "increase", " ", "in", " ",
     "radiated", " ", "seismic", " ", 
    RowBox[{"energy", ".", " ", "Some"}], " ", "representative", " ", "fault",
     " ", "dimensions"}], ":"}]}]], "Text",ExpressionUUID->"aec5fafb-ffe6-\
4d5e-9168-35020c6173a4"],

Cell[BoxData[
 "M6: fault area ~ 20 km x 10 km, slip ~ 0.5 m\n" <> \
$CellContext`StringTrimRight[
  "      (e.g. a moderate damaging earthquake)                   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  M7: fault area ~ 70 km x 25 km, slip ~ 1 m                 "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "      (e.g. 2023 Turkey Mw 7.8)                               "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  M9: fault area ~ 1000 km x 200 km, slip ~ 10 m             "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "      (e.g. 2011 Tohoku, 2004 Sumatra)                        "]], "Text",E\
xpressionUUID->"15a5406e-b3a5-4231-8068-22cd3384c8c0"]
}, Open  ]],

Cell[CellGroupData[{


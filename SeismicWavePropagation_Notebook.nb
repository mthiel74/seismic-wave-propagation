Cell[CellGroupData[{

Cell["SECTION 10: GROUND MOTION VISUALIZATION --- THE HERO", "Section",ExpressionUUID->"1f0adf3f-d8aa-4ef4-9f2b-393cd9782521"],

Cell[CellGroupData[{

Cell["10.1 What is a Ground Motion Visualization?", "Subsection",ExpressionUUID->"f67d4916-cf4c-4b6e-b7cb-839edb41435d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"A", " ", "Ground", " ", "Motion", " ", "Visualization", " ", 
   RowBox[{"(", "GMV", ")"}], " ", "is", " ", "a", " ", "powerful", " ", 
   "technique", " ", "for", " ", "displaying", " ", "seismic", " ", "wave", " ",
    "propagation", " ", "as", " ", "recorded", " ", "by", " ", "a", " ", 
   "network", " ", "of", " ", 
   RowBox[{"seismometers", ".", " ", "Developed"}], " ", "and", " ", 
   "popularized", " ", "by", " ", "IRIS", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
     "Incorporated", " ", "Research", " ", "Institutions", " ", "for", " ", 
      "Seismology"}], ",", " ", 
     RowBox[{"now", " ", "part", " ", "of", " ", "EarthScope"}]}], ")"}]}], ",",
   " ", 
  RowBox[{
  "GMVs", " ", "have", " ", "become", " ", "one", " ", "of", " ", "the", " ", 
   "most", " ", "compelling", " ", "ways", " ", "to", " ", "communicate", " ",
    "the", " ", "physics", " ", "of", " ", "seismic", " ", "waves", " ", "to",
    " ", "both", " ", "specialists", " ", "and", " ", "the", " ", "general", " ", 
   RowBox[{"public", "."}]}]}]], "Text",ExpressionUUID->"36916e6f-83d5-49d7-\
902d-783dc1cf961e"],

Cell[BoxData[
 "In a GMV, each seismometer station is represented as a colored dot on a \
map. The color encodes the instantaneous ground displacement:\n" <> \
$CellContext`StringTrimRight[
  "  - Red indicates the ground is moving UP                     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Blue indicates the ground is moving DOWN                  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - White/neutral indicates no displacement                   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Color intensity indicates amplitude                       "]], "Text",E\
xpressionUUID->"f9aa954d-83b3-470f-8674-697c550324f6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "As", " ", "seismic", " ", "waves", " ", "sweep", " ", "through", " ", 
   "the", " ", "station", " ", "network"}], ",", " ", 
  RowBox[{
  "the", " ", "coherent", " ", "wavefronts", " ", "become", " ", "visible", " ",
    "as", " ", "bands", " ", "of", " ", "alternating", " ", "red", " ", "and",
    " ", "blue", " ", "that", " ", "propagate", " ", "outward", " ", "from", " ",
    "the", " ", 
   RowBox[{"epicenter", ".", " ", "The"}], " ", "result", " ", "is", " ", "a",
    " ", "direct"}], ",", " ", 
  RowBox[{
   RowBox[{
   "visceral", " ", "visualization", " ", "of", " ", "the", " ", "passage", " ",
     "of", " ", "seismic", " ", "waves", " ", "through", " ", "the", " ", 
    RowBox[{"Earth", " ", "--"}]}], "-", " ", 
   RowBox[{
   "the", " ", "viewer", " ", "literally", " ", "watches", " ", "the", " ", 
    "ground", " ", 
    RowBox[{"shake", "."}]}]}]}]], "Text",ExpressionUUID->"e226fa66-b223-4291-\
9d3f-0afdfd204f39"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.2 How real GMVs are constructed", "Subsection",ExpressionUUID->"089d24cc-3fcd-4223-a466-955a28547e62"],

Cell[BoxData[
 RowBox[{"The", " ", 
  RowBox[{"IRIS", "/", "EarthScope"}], " ", "pipeline", " ", "for", " ", 
  "producing", " ", "GMVs", " ", "involves", " ", "several", " ", "data", " ",
   "processing", " ", 
  RowBox[{"steps", ":"}]}]], "Text",ExpressionUUID->"6019f552-c6a2-4699-9397-\
c1e4032ed713"],

Cell[BoxData[
 "1. Waveform retrieval: Download continuous seismogram data\n" <> \
$CellContext`StringTrimRight[
  "   from all available broadband stations in the region of     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   interest (typically hundreds to thousands of stations).    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   The vertical component (BHZ or LHZ channel) is used.       "]], "Text",E\
xpressionUUID->"d26ed80f-5069-49ea-afb0-d4e508317eee"],

Cell[BoxData[
 "2. Instrument response removal: Each seismometer has its\n" <> \
$CellContext`StringTrimRight[
  "   own frequency response. The instrument response is         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   deconvolved to convert from raw digital counts to true     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   ground displacement (in metres).                           "]], "Text",E\
xpressionUUID->"35c29ea2-c14c-4477-9c1d-cd468d6707d2"],

Cell[BoxData[
 "3. Bandpass filtering: The data is filtered to isolate the\n" <> \
$CellContext`StringTrimRight[
  "   frequency band of interest. For large earthquakes          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   (M >= 6.5), the typical IRIS band is 0.002-0.01 Hz         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   (periods of 100-500 seconds). This long-period band is    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   chosen because:                                            "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "     - It emphasizes the dominant surface waves               "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "     - Long-period waves are coherent over large distances    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "     - Noise and local site effects are minimized             "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "     - The wavefronts are smooth and visually clear           "]], "Text",E\
xpressionUUID->"818fe7f6-1edf-4338-9a26-c00aa5206a25"],

Cell[BoxData[
 "4. Per-station normalization: Each station's seismogram is\n" <> \
$CellContext`StringTrimRight[
  "   normalized independently to its own peak absolute          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   amplitude. This is the crucial step that makes GMVs work:  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   without normalization, stations near the epicenter would   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   dominate the display (their amplitudes are orders of       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   magnitude larger than distant stations), and the wave      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   passage at distant stations would be invisible. After      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   normalization, every station responds with comparable      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   visual intensity, making the wavefront coherent across     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   the entire network.                                        "]], "Text",E\
xpressionUUID->"5fe6fefb-cef8-48e5-8235-8cf7025dc500"],

Cell[BoxData[
 "5. Gain amplification: A gain factor (typically 5) is\n" <> \
$CellContext`StringTrimRight[
  "   applied after normalization. This means the color          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   saturates when the displacement exceeds 1/gain = 20%       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   of the station's peak amplitude. The gain makes weaker     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   arrivals (secondary phases, reflections) visible while     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   the dominant phases saturate to full color.                 "]], "Text",\
ExpressionUUID->"e03106c1-86b8-414c-a087-e874a64a3cfc"],

Cell[BoxData[
 "6. Color mapping: At each animation timestep, each station\n" <> \
$CellContext`StringTrimRight[
  "   dot is colored based on its normalized, amplified           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   displacement: the color ranges from saturated blue          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   (maximum negative displacement) through white (zero)       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "   to saturated red (maximum positive displacement).          "]], "Text",E\
xpressionUUID->"2dcb7436-31a9-4efc-9ddf-27ca1c406f17"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.3 Our synthetic GMV", "Subsection",ExpressionUUID->"2d97f988-34e9-433b-ba95-96186d35a08d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Rather", " ", "than", " ", "downloading", " ", "real", " ", "waveform", " ",
    "data", " ", 
   RowBox[{"(", 
    RowBox[{
    "which", " ", "would", " ", "require", " ", "significant", " ", "data", " ",
      "access", " ", "and", " ", "processing", " ", "infrastructure"}], 
    ")"}]}], ",", " ", 
  RowBox[{
  "we", " ", "construct", " ", "a", " ", "synthetic", " ", "GMV", " ", "from",
    " ", "first", " ", 
   RowBox[{"principles", ".", " ", "The"}], " ", "key", " ", "ingredients", " ", 
   RowBox[{"are", ":"}]}]}]], "Text",ExpressionUUID->"b962c895-39de-43ce-b9b7-\
405794df1c04"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Station", " ", 
   RowBox[{"network", ":", " ", 
    RowBox[{
    "We", " ", "generate", " ", "a", " ", "synthetic", " ", "network", " ", 
     "of", " ", "approximately", " ", "2000", " ", "stations", " ", 
     "distributed", " ", "across", " ", "Europe", " ", "and", " ", "the", " ",
      "Mediterranean"}]}]}], ",", " ", 
  RowBox[{
  "matching", " ", "the", " ", "approximate", " ", "station", " ", "density", 
   " ", "of", " ", "real", " ", "European", " ", "seismic", " ", "networks", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"ORFEUS", ",", " ", "GEOFON", ",", " ", 
      RowBox[{"etc", "."}]}], ")"}], ".", " ", "Stations"}], " ", "are", " ", 
   "placed", " ", "preferentially", " ", "on", " ", "land", " ", "areas", " ",
    "using", " ", "the", " ", "GeoPosition", " ", 
   RowBox[{"framework", "."}]}]}]], "Text",ExpressionUUID->"c363be48-2405-\
41e9-aee2-e40493a68f15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Travel", " ", 
   RowBox[{"times", ":", " ", 
    RowBox[{"For", " ", "each", " ", "station"}]}]}], ",", " ", 
  RowBox[{
   RowBox[{"we", " ", "compute", " ", "the", " ", "P"}], "-", "wave"}], ",", 
  " ", 
  RowBox[{"S", "-", "wave"}], ",", " ", 
  RowBox[{
   RowBox[{
   "and", " ", "Rayleigh", " ", "wave", " ", "arrival", " ", "times", " ", 
    "using", " ", "our", " ", "PREM", " ", "velocity", " ", "model", " ", 
    "and", " ", "the", " ", "travel", " ", "time", " ", "curves", " ", 
    "derived", " ", "in", " ", "Section", " ", "4.", " ", "The", " ", 
    "epicentral", " ", "distance", " ", "to", " ", "each", " ", "station", " ",
     "is", " ", "computed", " ", "from", " ", "the", " ", "great"}], "-", 
   RowBox[{
   "circle", " ", "distance", " ", "using", " ", "the", " ", "geodesic", " ", 
    
    RowBox[{"formula", "."}]}]}]}]], "Text",ExpressionUUID->"22adc522-4733-\
4b48-b2c1-5f34e9313b88"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Synthetic", " ", 
   RowBox[{"seismogram", ":", " ", 
    RowBox[{"At", " ", "each", " ", "station"}]}]}], ",", " ", 
  RowBox[{
  "we", " ", "construct", " ", "a", " ", "synthetic", " ", "ground", " ", 
   "displacement", " ", "trace", " ", "as", " ", "the", " ", "superposition", 
   " ", "of", " ", "Ricker", " ", "wavelets", " ", "centered", " ", "at", " ",
    "the", " ", "predicted", " ", "arrival", " ", "time", " ", "of", " ", 
   "each", " ", "phase", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"P", ",", " ", "S", ",", " ", "Rayleigh"}], ")"}], 
    "."}]}]}]], "Text",ExpressionUUID->"07307348-0a1a-4279-ba4f-5cd4fa172b69"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.4 The Ricker wavelet", "Subsection",ExpressionUUID->"9d0af1b2-d0eb-49cd-8dd3-62be23941f54"],

Cell[BoxData[
 RowBox[{
  RowBox[{"The", " ", "Ricker", " ", "wavelet", " ", 
   RowBox[{"(", 
    RowBox[{
    "also", " ", "known", " ", "as", " ", "the", " ", "\"\<Mexican hat\>\"", " ",
      "wavelet"}], ")"}], " ", "is", " ", "a", " ", "zero"}], "-", 
  RowBox[{
  "phase", " ", "wavelet", " ", "widely", " ", "used", " ", "in", " ", 
   "exploration", " ", "seismology", " ", "and", " ", "synthetic", " ", 
   "seismogram", " ", 
   RowBox[{"construction", ".", " ", "It"}], " ", "is", " ", "the", " ", 
   "negative", " ", "normalized", " ", "second", " ", "derivative", " ", "of",
    " ", "a", " ", 
   RowBox[{"Gaussian", ":"}]}]}]], "Text",ExpressionUUID->"d593d2c9-39b6-492b-\
9bb2-5d2712cd94b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"psi", 
   RowBox[{"(", "t", ")"}]}], " ", "=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{"2", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Pi", " ", "f0", " ", "t"}], ")"}], "^", "2"}]}]}], ")"}], " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Pi", " ", "f0", " ", "t"}], ")"}], "^", "2"}]}], 
    "]"}]}]}]], "Text",ExpressionUUID->"9a3f3e3f-be72-44b0-8458-462e3a8baffc"],

Cell[BoxData[
 RowBox[{"where", " ", "f0", " ", "is", " ", "the", " ", "dominant", " ", 
  RowBox[{"(", "peak", ")"}], " ", 
  RowBox[{"frequency", ".", " ", "Key"}], " ", 
  RowBox[{"properties", ":"}]}]], "Text",ExpressionUUID->"57d4de12-8a30-4d37-\
94f6-e182ba49026c"],

Cell[BoxData[
 "- Clean bipolar pulse: one central positive peak flanked\n" <> \
$CellContext`StringTrimRight[
  "    by two symmetric negative troughs                         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Zero mean (the wavelet integrates to zero)                "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Compact support in both time and frequency domains        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - The dominant frequency f0 controls the wavelet width:     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    larger f0 gives a narrower, higher-frequency pulse        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Peak frequency equals f0; bandwidth ~ f0                  "]], "Text",E\
xpressionUUID->"acf5bd0c-7c66-46f7-8017-2fc541536fef"],

Cell[BoxData[
 "We chose the Ricker wavelet over a simple sine burst or Gaussian pulse \
because:\n" <> $CellContext`StringTrimRight[
  "  - Its bipolar nature naturally produces the alternating     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    red-blue pattern characteristic of real GMVs              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - It is finite-duration (unlike a sinusoid), avoiding       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    Moire artifacts from sustained oscillations               "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - It has a well-defined dominant frequency, allowing us     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    to match the IRIS filter band                             "]], "Text",E\
xpressionUUID->"48a3caf3-4cbc-4ba7-90e2-71a1cce4befc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "We", " ", "use", " ", "different", " ", "dominant", " ", "frequencies", " ",
    "for", " ", "each", " ", "seismic", " ", "phase"}], ",", " ", 
  RowBox[{"reflecting", " ", "their", " ", "different", " ", "frequency", " ", 
   RowBox[{"content", ":"}]}]}]], "Text",ExpressionUUID->"35764a25-56f9-4c65-\
9ef0-1ede196c9d88"],

Cell[BoxData[
 "P-wave:    f0 = 0.007 Hz  (dominant period ~ 143 s)\n" <> \
$CellContext`StringTrimRight[
  "  S-wave:    f0 = 0.005 Hz  (dominant period ~ 200 s)         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  Rayleigh:  f0 = 0.003 Hz  (dominant period ~ 333 s)         "]], "Text",E\
xpressionUUID->"6f108c1e-09de-4480-ade6-d3e4c396566c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
    "These", " ", "frequencies", " ", "fall", " ", "within", " ", "the", " ", 
     "IRIS", " ", "long"}], "-", 
    RowBox[{"period", " ", "filter", " ", "band", " ", 
     RowBox[{"(", 
      RowBox[{"0.002", "-", 
       RowBox[{"0.01", " ", "Hz"}]}], ")"}], " ", "used", " ", "for", " ", 
     "M"}]}], " ", ">=", " ", 
   RowBox[{"6.5", " ", "earthquakes"}]}], ",", " ", 
  RowBox[{
  "ensuring", " ", "that", " ", "our", " ", "synthetic", " ", "GMV", " ", 
   "has", " ", "a", " ", "realistic", " ", "visual", " ", 
   RowBox[{"appearance", "."}]}]}]], "Text",ExpressionUUID->"9aeda9b0-b5ae-\
4fad-88af-9e385eaa76dd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.5 Per-station normalization", "Subsection",ExpressionUUID->"30f2f2fe-4f0c-4dce-8870-60249c3516f4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Following", " ", "the", " ", "IRIS", " ", "methodology"}], ",", 
  " ", 
  RowBox[{"we", " ", "normalize", " ", "each", " ", 
   RowBox[{"station", "'"}], "s", " ", "synthetic", " ", "seismogram", " ", 
   "independently", " ", "to", " ", "its", " ", "own", " ", "peak", " ", 
   "absolute", " ", 
   RowBox[{"amplitude", ":"}]}]}]], "Text",ExpressionUUID->"1f0990e2-c035-\
4358-a02a-e0d40df5a097"],

Cell[BoxData[
 RowBox[{
  RowBox[{"u_norm", 
   RowBox[{"(", "t", ")"}]}], " ", "=", " ", 
  RowBox[{"gain", " ", "*", " ", "u", 
   RowBox[{
    RowBox[{"(", "t", ")"}], " ", "/", " ", 
    RowBox[{"Max", "[", 
     RowBox[{"Abs", "[", 
      RowBox[{"u", 
       RowBox[{"(", "t", ")"}]}], "]"}], "]"}]}]}]}]], "Text",ExpressionUUID->\
"9ecb79c3-4446-475e-9181-5cbd0a0a8c85"],

Cell[BoxData[
 RowBox[{
  RowBox[{"where", " ", "gain"}], " ", "=", " ", 
  RowBox[{"5", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"the", " ", "IRIS", " ", "standard"}], ")"}], ".", " ", 
    "After"}], " ", 
   RowBox[{"normalization", ":"}]}]}]], "Text",ExpressionUUID->"24e3ba62-62af-\
4e99-9ad6-7619d6cf05b0"],

Cell[BoxData[
 "- Every station's peak displacement maps to the same color\n" <> \
$CellContext`StringTrimRight[
  "    intensity, regardless of distance from the epicenter      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - The gain factor of 5 means the color saturates at         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    1/5 = 20% of peak amplitude                               "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - This makes weaker arrivals clearly visible: P-waves       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    typically saturate even though they are much weaker than  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    the Rayleigh wave that dominates the raw trace            "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - The result is a display where P, S, and Rayleigh wave     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    fronts are all visible as they sweep across the network   "]], "Text",E\
xpressionUUID->"94022599-50b7-42fa-9a15-3c9802b97a9c"],

Cell[BoxData[
 RowBox[{"This", " ", "normalization", " ", "is", " ", "the", " ", "key", " ",
   "to", " ", "why", " ", "GMVs", " ", "are", " ", "so", " ", "effective", " ",
   "as", " ", 
  RowBox[{"visualizations", ":", " ", 
   RowBox[{
   "it", " ", "compensates", " ", "for", " ", "geometric", " ", "spreading", " ",
     "and", " ", "makes", " ", "the", " ", "wave", " ", "passage", " ", 
    "visible", " ", "across", " ", "the", " ", "entire", " ", "network", " ", 
    
    RowBox[{"extent", "."}]}]}]}]], "Text",ExpressionUUID->"64032c7c-dd6d-\
448e-8f33-8c66fbf50523"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.6 Generating the GMV", "Subsection",ExpressionUUID->"bd38dbc5-5a4e-4db3-80a8-379e9e177c8d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "We", " ", "now", " ", "generate", " ", "the", " ", "Ground", " ", "Motion",
    " ", "Visualization", " ", "for", " ", "the", " ", "2025", " ", "Myanmar",
    " ", "Mw", " ", "7.7", " ", "earthquake"}], ",", " ", 
  RowBox[{
  "as", " ", "observed", " ", "across", " ", "a", " ", "synthetic", " ", 
   "European", " ", "station", " ", 
   RowBox[{"network", ".", " ", "The"}], " ", "earthquake", " ", "epicenter", 
   " ", "is", " ", "at", " ", "21.88", " ", "N"}], ",", " ", 
  RowBox[{
   RowBox[{"96.01", " ", 
    RowBox[{"E", ".", " ", "The"}], " ", "P"}], "-", 
   RowBox[{
   "wave", " ", "arrives", " ", "at", " ", "European", " ", "stations", " ", 
    "after", " ", "approximately", " ", "600"}], "-", 
   RowBox[{"900", " ", "seconds"}]}], ",", " ", 
  RowBox[{
   RowBox[{"with", " ", "the", " ", "S"}], "-", 
   RowBox[{"wave", " ", 
    RowBox[{"following", " ", "~", "400"}], " ", "seconds", " ", "later", " ",

       RowBox[{"M9", ".1", " ", "Tohoku", " ", "2011"}]}], ")"}], ".", " ", 
     "At"}], " ", "transform", " ", "boundaries", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"e", ".", "g", ".", " ", "the"}], " ", "San", " ", "Andreas", " ",
       "Fault"}], ")"}]}]}], ",", " ", 
  RowBox[{"plates", " ", "slide", " ", "past", " ", "one", " ", 
   RowBox[{"another", ".", " ", "At"}], " ", "divergent", " ", "boundaries", " ", 
   RowBox[{"(", 
    RowBox[{"mid", "-", 
     RowBox[{"ocean", " ", "ridges"}]}], ")"}]}], ",", " ", 
  RowBox[{"plates", " ", "pull", " ", 
   RowBox[{"apart", ".", " ", "Each"}], " ", "boundary", " ", "type", " ", 
   "produces", " ", "characteristic", " ", "seismicity", " ", "patterns", " ",
    "and", " ", "focal", " ", 
   RowBox[{"mechanisms", "."}]}]}]], "Text",ExpressionUUID->"fceadb00-864f-\

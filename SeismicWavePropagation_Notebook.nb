Cell[BoxData[
 RowBox[{
  RowBox[{"rho", " ", "*", " ", 
   RowBox[{"D", "^", "2"}], " ", 
   RowBox[{"u", " ", "/", " ", 
    RowBox[{"Dt", "^", "2"}]}]}], " ", "=", " ", 
  RowBox[{
   RowBox[{"Div", "[", "sigma", "]"}], " ", "+", " ", "f"}]}]], "Text",Express\
ionUUID->"4c30cc02-eb4f-4238-9e60-42746014304c"],

Cell[BoxData[
 "where:\n" <> $CellContext`StringTrimRight[
  "  rho     = mass density [kg/m^3]                             "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  u       = displacement vector field [m]                     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  sigma   = Cauchy stress tensor [Pa]                         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  f       = body force density (e.g. gravity) [N/m^3]         "]], "Text",E\
xpressionUUID->"3597ae27-7ffa-4571-805a-94a29c4acfb7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", " ", "seismic", " ", "wave", " ", "propagation"}], ",", " ", 
  
  RowBox[{"we", " ", "neglect", " ", "body", " ", "forces", " ", 
   RowBox[{"(", 
    RowBox[{
    "they", " ", "produce", " ", "only", " ", "static", " ", "deformation"}], 
    ")"}], " ", "and", " ", "focus", " ", "on", " ", "the", " ", "dynamic", " ",
    "perturbation", " ", "about", " ", "the", " ", "equilibrium", " ", 
   RowBox[{"state", "."}]}]}]], "Text",ExpressionUUID->"14189d68-3064-43af-\
87f5-7c9f0b78f36a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.2 Hooke's law for isotropic elastic media", "Subsection",ExpressionUUID->"4cd4f3d8-e135-40bb-905f-1b99a845522d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", " ", "a", " ", "linear"}], ",", " ", 
  RowBox[{"isotropic", " ", "elastic", " ", "solid"}], ",", " ", 
  RowBox[{
   RowBox[{"the", " ", "stress"}], "-", 
   RowBox[{"strain", " ", "relation", " ", 
    RowBox[{"(", 
     RowBox[{"generalized", " ", 
      RowBox[{"Hooke", "'"}], "s", " ", "law"}], ")"}], " ", 
    RowBox[{"is", ":"}]}]}]}]], "Text",ExpressionUUID->"1af20aa1-eeb3-4ecd-\
889e-438a1e644b1a"],

Cell[BoxData[
 RowBox[{"sigma_ij", " ", "=", " ", 
  RowBox[{
   RowBox[{"lambda", " ", "*", " ", "delta_ij", " ", "*", " ", "epsilon_kk"}],
    " ", "+", " ", 
   RowBox[{"2", " ", "mu", " ", "*", " ", "eps_ij"}]}]}]], "Text",ExpressionUU\
ID->"e7daf283-e7c3-45fd-bd64-691915c54b70"],

Cell[BoxData[
 "where:\n" <> $CellContext`StringTrimRight[
  "  lambda, mu = Lame parameters [Pa]                           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  delta_ij   = Kronecker delta                                "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  epsilon_ij = (1/2)(du_i/dx_j + du_j/dx_i)  (strain tensor) "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  epsilon_kk = Div[u]  (volumetric strain / dilatation)       "]], "Text",E\
xpressionUUID->"1686a8ab-67fe-4469-99f0-997f1f001a82"],

Cell[BoxData[
 "The Lame parameter mu is the shear modulus (rigidity), and lambda is \
related to the bulk modulus K by:\n" <> $CellContext`StringTrimRight[
  "  K = lambda + (2/3) mu                                       "]], "Text",E\
xpressionUUID->"90e6b80c-9fa0-442b-b228-c91545eb8f6e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.3 The Navier-Cauchy equation", "Subsection",ExpressionUUID->"60e033c3-20d4-4118-add4-10e0a8ddec7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Substituting", " ", 
   RowBox[{"Hooke", "'"}], "s", " ", "law", " ", "into", " ", "the", " ", 
   "equation", " ", "of", " ", "motion", " ", "and", " ", "using", " ", "the",
    " ", "strain"}], "-", 
  RowBox[{
  "displacement", " ", "relation", " ", "yields", " ", "the", " ", "Navier"}],
   "-", 
  RowBox[{
  "Cauchy", " ", "equation", " ", "for", " ", "elastic", " ", "wave", " ", 
   RowBox[{"propagation", ":"}]}]}]], "Text",ExpressionUUID->"4de3bf9f-f819-\
4761-ad51-a26c8de65c62"],

Cell[BoxData[
 "rho * D^2 u / Dt^2 = (lambda + 2 mu) Grad[Div[u]]\n" <> \
$CellContext`StringTrimRight[
  "                        - mu Curl[Curl[u]]                    "]], "Text",E\
xpressionUUID->"ea217338-0bfb-456b-90d8-5bc6fd97fcb1"],

Cell[BoxData[
 "or equivalently, using the vector identity\n" <> \
$CellContext`StringTrimRight[
  "  Curl[Curl[u]] = Grad[Div[u]] - Laplacian[u]:               "]], "Text",Ex\
pressionUUID->"0b55a42d-3339-4d33-b6bf-2ea2740a723c"],

Cell[BoxData[
 "rho * D^2 u / Dt^2 = (lambda + mu) Grad[Div[u]]\n" <> \
$CellContext`StringTrimRight[
  "                        + mu Laplacian[u]                     "]], "Text",E\
xpressionUUID->"ce87f439-c03e-4f42-9531-b2c659c4ca69"],

Cell[BoxData[
 RowBox[{"This", " ", "is", " ", "a", " ", "coupled", " ", "system", " ", 
  "of", " ", "PDEs", " ", "for", " ", "the", " ", "three", " ", "components", 
  " ", "of", " ", 
  RowBox[{"displacement", ".", " ", "The"}], " ", "key", " ", "insight", " ", 
  "of", " ", "seismology", " ", "is", " ", "that", " ", "it", " ", "can", " ",
   "be", " ", "decoupled", " ", "using", " ", "the", " ", "Helmholtz", " ", 
  RowBox[{"decomposition", "."}]}]], "Text",ExpressionUUID->"57834db4-35f9-\
4965-b8a0-10c7d99c2f40"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.4 Helmholtz decomposition: P- and S-waves", "Subsection",ExpressionUUID->"78970a61-24b8-42cc-aeaf-e534996a6b4b"],

Cell[BoxData[
 RowBox[{"Any", " ", "vector", " ", "field", " ", "can", " ", "be", " ", 
  "decomposed", " ", "into", " ", "irrotational", " ", "and", " ", 
  "solenoidal", " ", 
  RowBox[{"parts", ":"}]}]], "Text",ExpressionUUID->"2280f01c-6b30-460c-acb7-\
ed79784d9f1c"],

Cell[BoxData[
 RowBox[{"u", " ", "=", " ", 
  RowBox[{
   RowBox[{"Grad", "[", "phi", "]"}], " ", "+", " ", 
   RowBox[{"Curl", "[", "psi", "]"}]}]}]], "Text",ExpressionUUID->"d73f9992-\
8b60-4116-95b7-7a1522971d88"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "where", " ", "phi", " ", "is", " ", "a", " ", "scalar", " ", "potential", " ",
    "and", " ", "psi", " ", "is", " ", "a", " ", "vector", " ", 
   RowBox[{"potential", ".", " ", "Substituting"}], " ", "into", " ", "the", " ",
    "Navier"}], "-", 
  RowBox[{"Cauchy", " ", "equation", " ", "and", " ", 
   RowBox[{"separating", ":"}]}]}]], "Text",ExpressionUUID->"0d65b5cd-58c2-\
4a05-ab67-cfdcec14da0f"],

Cell[BoxData[
 "P-waves (from phi, the compressional potential):\n" <> \
$CellContext`StringTrimRight[
  "  Laplacian[phi] = (1/alpha^2) * D^2 phi / Dt^2              "]], "Text",Ex\
pressionUUID->"ab7d8bbb-6388-4d5e-b232-61aeba5e671b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"where", " ", "alpha"}], " ", "=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"lambda", " ", "+", " ", 
      RowBox[{"2", " ", "mu"}]}], ")"}], " ", "/", " ", "rho"}], 
   "]"}]}]], "Text",ExpressionUUID->"1ffcf864-11c7-4fe2-89c2-c542456eecaf"],

Cell[BoxData[
 "S-waves (from psi, the shear potential):\n" <> $CellContext`StringTrimRight[
  "  Laplacian[psi] = (1/beta^2) * D^2 psi / Dt^2               "]], "Text",Ex\
pressionUUID->"5ba7d664-c509-4af9-9616-0421a7a3b6f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"where", " ", "beta"}], " ", "=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"mu", " ", "/", " ", "rho"}], "]"}]}]], "Text",ExpressionUUID->\
"2ae28453-f0a5-40a7-b132-dbce5b3a5b82"],

Cell[BoxData[
 RowBox[{"These", " ", "are", " ", "classical", " ", "wave", " ", 
  RowBox[{"equations", ".", " ", "The"}], " ", "solutions", " ", "propagate", 
  " ", "at", " ", "velocities", " ", "alpha", " ", 
  RowBox[{"(", 
   RowBox[{"P", "-", "wave"}], ")"}], " ", "and", " ", "beta", " ", 
  RowBox[{"(", 
   RowBox[{"S", "-", "wave"}], ")"}], " ", 
  RowBox[{"respectively", "."}]}]], "Text",ExpressionUUID->"e6f0bfd0-b73c-\
4d10-a201-9850bd548b90"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.5 P-wave properties", "Subsection",ExpressionUUID->"b8fcc607-42ab-4505-8f80-4564939c91c5"],

Cell[BoxData[
 RowBox[{"P", "-", 
  RowBox[{"waves", " ", 
   RowBox[{"(", 
    RowBox[{"primary", " ", "waves"}], ")"}], " ", "are", " ", 
   RowBox[{"compressional", ":", " ", 
    RowBox[{
    "the", " ", "particle", " ", "motion", " ", "is", " ", "parallel", " ", 
     RowBox[{"(", "longitudinal", ")"}], " ", "to", " ", "the", " ", 
     "direction", " ", "of", " ", "wave", " ", 
     RowBox[{"propagation", ".", " ", "They"}], " ", "are", " ", "the", " ", 
     "fastest", " ", "seismic", " ", "waves", " ", "and", " ", "therefore", " ",
      "arrive", " ", "first", " ", "at", " ", "any", " ", 
     RowBox[{"seismometer", ".", " ", "Typical"}], " ", "values"}], 
    ":"}]}]}]], "Text",ExpressionUUID->"a56c76ba-f4e7-4e0d-bf42-20d9b395118e"],

Cell[BoxData[
 "In the crust:      alpha ~ 6.0 km/s\n" <> $CellContext`StringTrimRight[
  "  In the upper mantle: alpha ~ 8.0 km/s                      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  At the core-mantle boundary: alpha ~ 13.7 km/s             "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  In the outer core (liquid): alpha ~ 8.0-10.3 km/s          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  In the inner core: alpha ~ 11.0-11.3 km/s                  "]], "Text",Ex\
pressionUUID->"fe286221-b55a-4634-8a46-6905146daded"],

Cell[BoxData[
 RowBox[{
  RowBox[{"P", "-", 
   RowBox[{
   "waves", " ", "can", " ", "propagate", " ", "through", " ", "both", " ", 
    "solids", " ", "and", " ", "liquids"}]}], ",", " ", 
  RowBox[{
  "because", " ", "compression", " ", "does", " ", "not", " ", "require", " ",
    "shear", " ", 
   RowBox[{"rigidity", "."}]}]}]], "Text",ExpressionUUID->"3e1eeb9b-423e-4f95-\
8589-6b3db39b97a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.6 S-wave properties", "Subsection",ExpressionUUID->"16c4e273-129f-4369-8a38-a7ddbee3345b"],

Cell[BoxData[
 RowBox[{"S", "-", 
  RowBox[{"waves", " ", 
   RowBox[{"(", 
    RowBox[{"secondary", " ", "waves"}], ")"}], " ", "are", " ", "shear", " ", 
   RowBox[{"waves", ":", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "particle", " ", "motion", " ", "is", " ", "perpendicular", " ", 
      RowBox[{"(", "transverse", ")"}], " ", "to", " ", "the", " ", 
      "direction", " ", "of", " ", 
      RowBox[{"propagation", ".", " ", "They"}], " ", "are", " ", "slower", " ",
       "than", " ", "P"}], "-", 
     RowBox[{
     "waves", " ", "by", " ", "a", " ", "factor", " ", "that", " ", "depends",
       " ", "on", " ", 
      RowBox[{"Poisson", "'"}], "s", " ", "ratio"}]}], ":"}]}]}]], "Text",Expr\
essionUUID->"5a8c239f-c6f1-49e4-b97c-e17bad213837"],

Cell[BoxData[
 "alpha / beta = Sqrt[(lambda + 2 mu) / mu]\n" <> \
$CellContext`StringTrimRight[
  "               = Sqrt[2(1 - nu) / (1 - 2 nu)]                "]], "Text",Ex\
pressionUUID->"79fb7fba-d33b-4b3e-9632-53dfea4f1021"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
   "For", " ", "a", " ", "Poisson", " ", "ratio", " ", "of", " ", "nu"}], " ",
    "=", " ", 
   RowBox[{"0.25", " ", 
    RowBox[{"(", 
     RowBox[{
     "a", " ", "common", " ", "approximation", " ", "for", " ", "crustal", " ",
       "rock"}], ")"}]}]}], ",", " ", 
  RowBox[{
   RowBox[{"this", " ", "gives", " ", 
    RowBox[{"alpha", "/", "beta"}]}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Sqrt", "[", "3", "]"}], " ", "~", " ", "1.73"}], 
    "."}]}]}]], "Text",ExpressionUUID->"9aeea10c-5353-4f96-bde8-e25249c686b2"],

Cell[BoxData[
 RowBox[{"Crucially", ",", " ", 
  RowBox[{"S", "-", 
   RowBox[{
   "waves", " ", "CANNOT", " ", "propagate", " ", "in", " ", "fluids"}]}], ",",
   " ", 
  RowBox[{
   RowBox[{"because", " ", "the", " ", "shear", " ", "modulus", " ", "mu"}], 
   " ", "=", " ", 
   RowBox[{"0", " ", "in", " ", "a", " ", 
    RowBox[{"liquid", ".", " ", "This"}], " ", "has", " ", "a", " ", 
    "profound", " ", 
    RowBox[{"consequence", ":", " ", 
     RowBox[{"S", "-", 
      RowBox[{
      "waves", " ", "are", " ", "blocked", " ", "by", " ", "the", " ", 
       "liquid", " ", "outer", " ", "core"}]}]}]}]}], ",", " ", 
  RowBox[{
   RowBox[{
   "creating", " ", "a", " ", "\"\<shadow zone\>\"", " ", "for", " ", 
    "direct", " ", "S"}], "-", 
   RowBox[{
   "wave", " ", "arrivals", " ", "at", " ", "epicentral", " ", "distances", " ",
     "between", " ", "about", " ", "104", " ", "and", " ", "140", " ", 
    RowBox[{"degrees", ".", " ", "This"}], " ", "shadow", " ", "zone", " ", 
    "was", " ", "one", " ", "of", " ", "the", " ", "key", " ", "pieces", " ", 
    "of", " ", "evidence", " ", "proving", " ", "the", " ", "existence", " ", 
    "of", " ", "a", " ", "liquid", " ", "outer", " ", "core", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Oldham", " ", "1906"}], ",", " ", 
       RowBox[{"Gutenberg", " ", "1913"}]}], ")"}], "."}]}]}]}]], "Text",Expre\
ssionUUID->"ec1c9893-4dfc-4e9e-9ad7-569ea5234f48"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.7 Surface waves", "Subsection",ExpressionUUID->"71b5761a-734f-49b1-87cc-f744ef274ca4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"In", " ", "addition", " ", "to", " ", "body", " ", "waves", " ", 
   RowBox[{"(", 
    RowBox[{"P", " ", "and", " ", "S"}], ")"}]}], ",", " ", 
  RowBox[{
  "the", " ", "free", " ", "surface", " ", "of", " ", "the", " ", "Earth", " ",
    "supports", " ", "surface", " ", "waves"}], ",", " ", 
  RowBox[{
   RowBox[{
   "which", " ", "are", " ", "confined", " ", "to", " ", "the", " ", "near"}],
    "-", 
   RowBox[{
   "surface", " ", "region", " ", "and", " ", "decay", " ", "exponentially", " ",
     "with", " ", 
    RowBox[{"depth", ".", " ", "There"}], " ", "are", " ", "two", " ", 
    RowBox[{"types", ":"}]}]}]}]], "Text",ExpressionUUID->"5c8e9366-4842-4c8a-\
8158-3a8b49699b14"],

Cell[BoxData[
 "Rayleigh waves (Lord Rayleigh 1885):\n" <> $CellContext`StringTrimRight[
  "  - Retrograde elliptical particle motion in the vertical     "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    plane containing the propagation direction                "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Velocity ~ 0.92 beta for a Poisson solid                 "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Amplitude decays exponentially with depth, with           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    significant motion down to about one wavelength           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Exist on any free surface of an elastic half-space        "]], "Text",E\
xpressionUUID->"fd639c96-f272-4d2e-aea1-d85557ace52f"],

Cell[BoxData[
 "Love waves (A. E. H. Love 1911):\n" <> $CellContext`StringTrimRight[
  "  - Transverse horizontal particle motion (SH polarization)  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Require a low-velocity layer over a half-space            "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Slightly faster than Rayleigh waves                      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Dispersive: velocity depends on frequency                 "]], "Text",E\
xpressionUUID->"681d57a1-32cd-4c19-8b35-4c5d7de47346"],

Cell[BoxData[
 "Surface waves are critically important because:\n" <> \
$CellContext`StringTrimRight[
  "  - Their amplitude decays as 1/Sqrt[r] (geometric spreading "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    on a 2D surface), compared to 1/r for body waves          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    spreading on a 3D wavefront. This means surface waves    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    dominate far-field seismograms.                           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - They carry most of the energy in large earthquakes        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - They cause the majority of earthquake damage              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - On a sphere, the geometric spreading factor becomes      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    1/Sqrt[Sin[Delta]], where Delta is the epicentral         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    distance in radians. This produces a focusing effect      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    at the antipodal point (Delta = Pi), where Sin[Delta]    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    approaches zero and amplitudes are amplified.             "]], "Text",E\
xpressionUUID->"a885efee-1ea2-49a5-80f1-535b200083c0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.8 Attenuation", "Subsection",ExpressionUUID->"c025f88f-5ce4-49e9-accf-4b983c801beb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Real", " ", "seismic", " ", "waves", " ", "lose", " ", "energy", " ", "as",
    " ", "they", " ", "propagate"}], ",", " ", 
  RowBox[{"due", " ", "to", " ", "anelastic", " ", "absorption", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "conversion", " ", "of", " ", "mechanical", " ", "energy", " ", "to", " ",
       "heat", " ", "through", " ", "internal", " ", "friction", " ", "in", " ",
       "the", " ", "rock"}], ")"}], ".", " ", "This"}], " ", "is", " ", 
   "quantified", " ", "by", " ", "the", " ", "quality", " ", "factor", " ", 
   RowBox[{"Q", ":"}]}]}]], "Text",ExpressionUUID->"8b7c55b9-2751-44b0-bb8b-\
8590df724026"],

Cell[BoxData[
 RowBox[{"Amplitude", " ", "~", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", "Pi"}], " ", "f", " ", 
    RowBox[{"t", " ", "/", " ", "Q"}]}], "]"}]}]], "Text",ExpressionUUID->\
"400766e3-9653-4012-b058-4d7ab45fa092"],

Cell[BoxData[
 "where f is frequency and t is travel time. Typical values:\n" <> \
$CellContext`StringTrimRight[
  "  Q_P ~ 300-500 in the mantle                                "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  Q_S ~ 100-200 in the mantle (shear attenuation is higher)  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  Q ~ 5000+ in the inner core                                "]], "Text",Ex\
pressionUUID->"a431efea-4f0b-410e-9266-4869073dad6b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Low", " ", "Q", " ", "means", " ", "high", " ", 
   RowBox[{"attenuation", ".", " ", "The"}], " ", "asthenosphere", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
     "the", " ", "partially", " ", "molten", " ", "zone", " ", "beneath", " ",
       "the", " ", "lithosphere"}], ",", " ", 
     RowBox[{"80", "-", 
      RowBox[{"220", " ", "km", " ", "depth"}]}]}], ")"}], " ", "has", " ", 
   "particularly", " ", "low", " ", "Q", " ", "values"}], ",", " ", 
  RowBox[{
  "which", " ", "is", " ", "evidence", " ", "for", " ", "partial", " ", 
   "melting", " ", 
   RowBox[{"there", "."}]}]}]], "Text",ExpressionUUID->"c022c578-9972-487f-\
9536-8b62e03b8092"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Note", ":", " ", 
   RowBox[{
    RowBox[{"In", " ", "our", " ", "PREM"}], "-", 
    RowBox[{"based", " ", "simulations", " ", "below"}]}]}], ",", " ", 
  RowBox[{
   RowBox[{
   "we", " ", "compute", " ", "travel", " ", "times", " ", "using", " ", 
    "the", " ", "velocity", " ", "model", " ", "but", " ", "do", " ", "not", " ",
     "explicitly", " ", "model", " ", 
    RowBox[{"attenuation", ".", " ", "The"}], " ", "synthetic", " ", 
    "seismograms", " ", "use", " ", "Ricker", " ", "wavelets", " ", "whose", " ",
     "amplitude", " ", "is", " ", "determined", " ", "by", " ", "the", " ", 
    "per"}], "-", 
   RowBox[{
   "station", " ", "normalization", " ", "scheme", " ", "rather", " ", "than",
     " ", "by", " ", "physical", " ", 
    RowBox[{"attenuation", " ", "--"}]}], "-", " ", 
   RowBox[{
   "this", " ", "is", " ", "a", " ", "common", " ", "simplification", " ", 
    "in", " ", "Ground", " ", "Motion", " ", 
    RowBox[{"Visualizations", "."}]}]}]}]], "Text",ExpressionUUID->"13d291b3-\
fb46-4810-800e-7e0f666d9bb4"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["SECTION 3: THE PREM VELOCITY MODEL", "Section",ExpressionUUID->"79037c37-41cf-44cd-a197-5db5f1007c75"],

Cell[CellGroupData[{

Cell["3.1 Overview of PREM", "Subsection",ExpressionUUID->"86a4dfa2-9938-4417-ab92-9f28b539e9ed"],

Cell[BoxData[
 "The Preliminary Reference Earth Model (PREM) was published by Dziewonski & \
Anderson in 1981 and remains the standard 1-D reference model of the Earth's \
interior. It was constructed by inverting a massive dataset comprising:\n" <> \
$CellContext`StringTrimRight[
  "  - Free oscillation eigenfrequencies (normal modes)          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Surface wave dispersion measurements                      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Body wave travel times from the ISC bulletin              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Astronomical-geodetic constraints (mass, moment of        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    inertia)                                                  "]], "Text",E\
xpressionUUID->"c8b81980-886d-40c4-8b1c-ebd3edfc844c"],


Cell["SECTION 1: WHAT IS AN EARTHQUAKE?", "Section",ExpressionUUID->"a3096143-fe04-4ab2-8c53-15e59700cde2"],

Cell[CellGroupData[{

Cell["1.1 Earth's interior structure", "Subsection",ExpressionUUID->"a0209a5e-184a-419e-8945-2bf30d332cd4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "Earth", " ", "is", " ", "a", " ", "differentiated", " ", 
   "body", " ", "with", " ", "a", " ", "layered", " ", "internal", " ", 
   "structure"}], ",", " ", 
  RowBox[{
  "shaped", " ", "by", " ", "4.5", " ", "billion", " ", "years", " ", "of", " ",
    "gravitational", " ", "separation", " ", "and", " ", "radiogenic", " ", 
   RowBox[{"heating", ".", " ", "At"}], " ", "the", " ", "centre", " ", 
   "lies", " ", "the", " ", "inner", " ", "core"}], ",", " ", 
  RowBox[{
   RowBox[{"a", " ", "solid", " ", "sphere", " ", "of", " ", "iron"}], "-", 
   RowBox[{
   "nickel", " ", "alloy", " ", "with", " ", "a", " ", "radius", " ", "of", " ",
     "approximately", " ", "1221", " ", 
    RowBox[{"km", ".", " ", "Temperatures"}], " ", "there", " ", 
    RowBox[{"reach", " ", "~", "5200"}], " ", "K"}]}], ",", " ", 
  RowBox[{"but", " ", "the", " ", "immense", " ", "pressure", " ", 
   RowBox[{"(", 
    RowBox[{"over", " ", "330", " ", "GPa"}], ")"}], " ", "keeps", " ", "the",
    " ", "iron", " ", 
   RowBox[{"crystalline", ".", " ", "Surrounding"}], " ", "it", " ", "is", " ",
    "the", " ", "outer", " ", "core"}], ",", " ", 
  RowBox[{
  "a", " ", "convecting", " ", "shell", " ", "of", " ", "liquid", " ", "iron",
    " ", "extending", " ", "to", " ", "a", " ", "radius", " ", "of", " ", 
   "3480", " ", "km", " ", "from", " ", "the", " ", 
   RowBox[{"centre", ".", " ", "This"}], " ", "liquid", " ", "layer", " ", 
   "is", " ", "the", " ", "source", " ", "of", " ", 
   RowBox[{"Earth", "'"}], "s", " ", "magnetic", " ", "field", " ", "via", " ",
    "the", " ", 
   RowBox[{"geodynamo", ".", " ", "Above"}], " ", "the", " ", "core", " ", 
   "lies", " ", "the", " ", "mantle"}], ",", " ", 
  RowBox[{
  "composed", " ", "primarily", " ", "of", " ", "silicate", " ", "minerals", " ", 
   RowBox[{"(", 
    RowBox[{"olivine", ",", " ", "pyroxene", ",", " ", 
     RowBox[{"perovskite", " ", "at", " ", "depth"}]}], ")"}]}], ",", " ", 
  RowBox[{
  "extending", " ", "to", " ", "a", " ", "mean", " ", "radius", " ", "of", " ",
    "6371", " ", 
   RowBox[{"km", ".", " ", "The"}], " ", "mantle", " ", "is", " ", "solid", " ",
    "on", " ", "seismic", " ", "time", " ", "scales", " ", "but", " ", 
   "flows", " ", "viscously", " ", "over", " ", "geological", " ", "time"}], ",",
   " ", 
  RowBox[{
  "driving", " ", "the", " ", "convection", " ", "currents", " ", "that", " ",
    "move", " ", "tectonic", " ", 
   RowBox[{"plates", ".", " ", "Finally"}]}], ",", " ", 
  RowBox[{
   RowBox[{"the", " ", "crust", " ", "is", " ", "a", " ", "thin", " ", 
    RowBox[{"veneer", " ", "--"}]}], "-", " ", 
   RowBox[{"just", " ", "5"}], "-", 
   RowBox[{
   "7", " ", "km", " ", "thick", " ", "beneath", " ", "the", " ", "oceans", " ", 
    RowBox[{"(", "basaltic", ")"}], " ", "and", " ", "30"}], "-", 
   RowBox[{
   "70", " ", "km", " ", "thick", " ", "beneath", " ", "the", " ", 
    "continents", " ", 
    RowBox[{
     RowBox[{"(", "granitic", ")"}], ".", " ", "It"}], " ", "is", " ", 
    "within", " ", "and", " ", "just", " ", "below", " ", "this", " ", 
    "crust", " ", "that", " ", "most", " ", "earthquakes", " ", 
    RowBox[{"originate", "."}]}]}]}]], "Text",ExpressionUUID->"8c963feb-931c-\
44d7-8924-3896ca1aa560"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1.2 Plate tectonics and strain accumulation", "Subsection",ExpressionUUID->"37b1d46a-53a6-47c9-ad84-4642d8ee2701"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Earth", "'"}], "s", " ", "surface", " ", "is", " ", "divided", " ",
     "into", " ", "approximately", " ", "15", " ", "major", " ", 
    "lithospheric", " ", "plates", " ", "and", " ", "numerous", " ", 
    "smaller", " ", 
    RowBox[{"ones", ".", " ", "These"}], " ", "rigid", " ", 
    RowBox[{"plates", " ", "--"}]}], "-", " ", 
   RowBox[{
   "comprising", " ", "the", " ", "crust", " ", "and", " ", "the", " ", 
    "uppermost", " ", "mantle", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"the", " ", "lithosphere"}], ")"}], " ", "--"}]}], "-", " ", 
   RowBox[{
   "float", " ", "atop", " ", "the", " ", "partially", " ", "molten", " ", 
    RowBox[{"asthenosphere", ".", " ", "Driven"}], " ", "by", " ", "mantle", " ",
     "convection"}]}], ",", " ", 
  RowBox[{"slab", " ", "pull", " ", "at", " ", "subduction", " ", "zones"}], ",",
   " ", 
  RowBox[{
   RowBox[{"and", " ", "ridge", " ", "push", " ", "at", " ", "mid"}], "-", 
   RowBox[{"ocean", " ", "ridges"}]}], ",", " ", 
  RowBox[{
  "the", " ", "plates", " ", "move", " ", "at", " ", "rates", " ", "of", " ", 
   "2", " ", "to", " ", "10", " ", "cm", " ", "per", " ", 
   RowBox[{"year", ".", " ", "While"}], " ", "this", " ", "may", " ", "seem", 

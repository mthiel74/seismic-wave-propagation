Cell[CellGroupData[{

Cell["SECTION 7: SUPERSHEAR RUPTURE", "Section",ExpressionUUID->"d103735c-0027-4742-99cd-2b098ca80d9c"],

Cell[CellGroupData[{

Cell["7.1 Sub-Rayleigh and supershear rupture", "Subsection",ExpressionUUID->"75a1f5e1-b045-4cfc-bcc0-f57a1190a6cc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"In", " ", "most", " ", "earthquakes"}], ",", " ", 
  RowBox[{
   RowBox[{
   "the", " ", "rupture", " ", "front", " ", "propagates", " ", "along", " ", 
    "the", " ", "fault", " ", "at", " ", "a", " ", "velocity", " ", "below", " ",
     "the", " ", "Rayleigh", " ", "wave", " ", 
    RowBox[{"speed", " ", "--"}]}], "-", " ", 
   RowBox[{"this", " ", "is", " ", "called", " ", "sub"}], "-", 
   RowBox[{"Rayleigh", " ", "rupture"}]}], ",", " ", 
  RowBox[{
   RowBox[{
   "and", " ", "typical", " ", "rupture", " ", "speeds", " ", "are", " ", 
    "70"}], "-", 
   RowBox[{"90", "%", " ", "of", " ", "the", " ", "local", " ", "S"}], "-", 
   RowBox[{"wave", " ", "velocity"}]}], ",", " ", 
  RowBox[{
   RowBox[{"roughly", " ", "2.5"}], "-", 
   RowBox[{"3.2", " ", 
    RowBox[{"km", "/", "s"}], " ", "in", " ", "the", " ", 
    RowBox[{"crust", "."}]}]}]}]], "Text",ExpressionUUID->"a7d63045-54c7-482b-\
9321-79794a42e885"],

Cell[BoxData[
 "However, theory predicts (Andrews 1976, Burridge 1973) that under certain \
conditions --- particularly on smooth, straight fault segments with \
sufficient pre-stress --- the rupture can accelerate through the \"forbidden \
zone\" between the Rayleigh and S-wave speeds and enter the supershear \
regime, where the rupture speed exceeds the S-wave velocity. This has been \
confirmed observationally in several events:\n" <> \
$CellContext`StringTrimRight[
  "  - 1999 Izmit, Turkey (Mw 7.4)                              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - 2001 Kunlun, Tibet (Mw 7.8)                              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - 2018 Palu, Indonesia (Mw 7.5)                             "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - 2025 Myanmar (Mw 7.7)                                    "]], "Text",Ex\
pressionUUID->"e4adadf7-93ef-4739-a5f5-1f252e68cf58"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.2 The Mach cone", "Subsection",ExpressionUUID->"d57c3706-c3ba-4d31-8236-94e5f0463eec"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
   "When", " ", "the", " ", "rupture", " ", "speed", " ", "v_rupture", " ", 
    "exceeds", " ", "the", " ", "S"}], "-", 
   RowBox[{"wave", " ", "speed", " ", "v_S"}]}], ",", " ", 
  RowBox[{
   RowBox[{"the", " ", "radiated", " ", "S"}], "-", 
   RowBox[{
   "waves", " ", "cannot", " ", "outrun", " ", "the", " ", "rupture", " ", 
    RowBox[{"front", ".", " ", "They"}], " ", "pile", " ", "up", " ", "along",
     " ", "a", " ", "conical", " ", 
    RowBox[{"wavefront", " ", "--"}]}], "-", " ", 
   RowBox[{"a", " ", "Mach", " ", 
    RowBox[{"cone", " ", "--"}]}], "-", " ", 
   RowBox[{
   "exactly", " ", "analogous", " ", "to", " ", "the", " ", "sonic", " ", 
    "boom", " ", "produced", " ", "by", " ", "a", " ", "supersonic", " ", 
    RowBox[{"aircraft", ".", " ", "The"}], " ", "half"}], "-", 
   RowBox[{"angle", " ", "of", " ", "the", " ", "Mach", " ", "cone", " ", 
    RowBox[{"is", ":"}]}]}]}]], "Text",ExpressionUUID->"7e8669f8-ca69-4d5d-\
ad40-868adb1687af"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Sin", "[", "theta_Mach", "]"}], " ", "=", " ", 
  RowBox[{"v_S", " ", "/", " ", "v_rupture"}]}]], "Text",ExpressionUUID->\
"fd489a58-4bcb-42fe-a4b6-ecfc4443fcf7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", " ", "the", " ", "2025", " ", "Myanmar", " ", "earthquake"}],
   ",", " ", 
  RowBox[{
  "preliminary", " ", "analyses", " ", "suggest", " ", "a", " ", "rupture", " ",
    "velocity", " ", "of", " ", "approximately", " ", "5.5", " ", 
   RowBox[{"km", "/", "s"}]}], ",", " ", 
  RowBox[{
   RowBox[{"while", " ", "the", " ", "local", " ", "crustal", " ", "S"}], "-", 
   RowBox[{"wave", " ", "speed", " ", "is", " ", "about", " ", "3.5", " ", 
    RowBox[{"km", "/", 
     RowBox[{"s", ".", " ", "This"}]}], " ", "gives", " ", "a", " ", "Mach", " ",
     "number", " ", "of", " ", 
    RowBox[{"5.5", "/", 
     RowBox[{"3.5", " ", "~", " ", "1.57"}]}], " ", "and", " ", "a", " ", 
    "Mach", " ", "cone", " ", "half"}], "-", 
   RowBox[{"angle", " ", "of", " ", "about", " ", "39.5", " ", 
    RowBox[{"degrees", "."}]}]}]}]], "Text",ExpressionUUID->"1c0cbdcc-9de0-\
4900-be50-7968acfcefa7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "practical", " ", "consequence", " ", "of", " ", "supershear", " ",
    "rupture", " ", "is", " ", "that", " ", "the", " ", "Mach", " ", "cone", " ",
    "concentrates", " ", "seismic", " ", "energy", " ", "along", " ", "a", " ",
    "narrow", " ", "beam"}], ",", " ", 
  RowBox[{
   RowBox[{
   "producing", " ", "unusually", " ", "intense", " ", "shaking", " ", "at", " ",
     "locations", " ", "that", " ", "lie", " ", "in", " ", "its", " ", 
    RowBox[{"path", " ", "--"}]}], "-", " ", 
   RowBox[{
   "analogous", " ", "to", " ", "the", " ", "focused", " ", "shock", " ", 
    "of", " ", "a", " ", "sonic", " ", 
    RowBox[{"boom", ".", " ", "This"}], " ", "can", " ", "lead", " ", "to", " ",
     "unexpectedly", " ", "severe", " ", "damage", " ", "at", " ", 
    "locations", " ", "far", " ", "from", " ", "the", " ", 
    RowBox[{"epicenter", "."}]}]}]}]], "Text",ExpressionUUID->"4457846d-49a1-\
4a7d-afe7-518bf7c84e44"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Plot", " ", "the", " ", "Mach", " ", "cone", " ", "geometry", " ", "for", " ",
    "the", " ", "2025", " ", "Myanmar", " ", "supershear", " ", "event"}], ",",
   " ", 
  RowBox[{
  "showing", " ", "the", " ", "Mach", " ", "angle", " ", "and", " ", 
   "wavefront", " ", "concentration"}]}]], "Text",ExpressionUUID->"c985cff0-\
e6d4-475e-a3e2-45a3a8263871"],


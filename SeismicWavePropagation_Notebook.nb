Cell[CellGroupData[{

Cell["SECTION 8: NUCLEAR TESTS AS SEISMIC SOURCES", "Section",ExpressionUUID->"4b437bf1-30a0-4869-b642-54b07fcdeb3e"],

Cell[CellGroupData[{

Cell["8.1 The Comprehensive Nuclear-Test-Ban Treaty", "Subsection",ExpressionUUID->"6e75962a-a23b-4f7d-821d-5bcf0b999bbb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"The", " ", "Comprehensive", " ", "Nuclear"}], "-", "Test", "-", 
   RowBox[{"Ban", " ", "Treaty", " ", 
    RowBox[{"(", "CTBT", ")"}]}]}], ",", " ", 
  RowBox[{"opened", " ", "for", " ", "signature", " ", "in", " ", "1996"}], ",",
   " ", 
  RowBox[{"bans", " ", "all", " ", "nuclear", " ", 
   RowBox[{"explosions", ".", " ", "Its"}], " ", "verification", " ", 
   "regime", " ", "relies", " ", "heavily", " ", "on", " ", 
   RowBox[{"seismology", ":", " ", 
    RowBox[{"the", " ", "International", " ", "Monitoring", " ", "System", " ", 
     RowBox[{"(", "IMS", ")"}], " ", "operates", " ", "a", " ", "global", " ",
      "network", " ", "of", " ", "seismic", " ", "stations", " ", 
     "specifically", " ", "designed", " ", "to", " ", "detect", " ", "and", " ",
      "identify", " ", "clandestine", " ", "nuclear", " ", 
     RowBox[{"tests", "."}]}]}]}]}]], "Text",ExpressionUUID->"65e40920-c653-\
462f-852d-529fd9c6424e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
   "Underground", " ", "nuclear", " ", "explosions", " ", "are", " ", 
    "efficient", " ", "seismic", " ", 
    RowBox[{"sources", " ", "--"}]}], "-", " ", 
   RowBox[{"even", " ", "a", " ", "1"}], "-", 
   RowBox[{
   "kiloton", " ", "device", " ", "produces", " ", "a", " ", "seismic", " ", 
    "signal", " ", "equivalent", " ", "to", " ", "roughly", " ", "a", " ", 
    "M4", " ", "earthquake"}]}], ",", " ", 
  RowBox[{
  "easily", " ", "detectable", " ", "at", " ", "teleseismic", " ", 
   "distances", " ", "by", " ", "the", " ", "IMS", " ", 
   RowBox[{"network", "."}]}]}]], "Text",ExpressionUUID->"df1389f1-a126-4e6a-\
b3a5-495e50384275"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8.2 Yield-magnitude scaling", "Subsection",ExpressionUUID->"c5cbfd24-9f44-4041-bc80-e6198aa13877"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "relationship", " ", "between", " ", "nuclear", " ", "yield", " ", 
   RowBox[{"(", 
    RowBox[{"Y", ",", " ", 
     RowBox[{"in", " ", "kilotons"}]}], ")"}], " ", "and", " ", "body"}], "-", 
  RowBox[{"wave", " ", "magnitude", " ", 
   RowBox[{"(", "mb", ")"}], " ", "is", " ", 
   RowBox[{"approximately", ":"}]}]}]], "Text",ExpressionUUID->"72bc0711-b579-\
4226-87e3-57b0a1a4977c"],

Cell[BoxData[
 RowBox[{"mb", " ", "=", " ", 
  RowBox[{"a", " ", "+", " ", 
   RowBox[{"b", " ", "*", " ", 
    RowBox[{"Log10", "[", "Y", "]"}]}]}]}]], "Text",ExpressionUUID->"4485dcbd-\
afb0-4b29-b7f4-e6ac0c3fc2d9"],

Cell[BoxData[
 "with typical values a ~ 4.0, b ~ 0.75 for well-coupled underground \
explosions. This means:\n" <> $CellContext`StringTrimRight[
  "  1 kt  -> mb ~ 4.0                                          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  10 kt -> mb ~ 4.75                                          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  100 kt -> mb ~ 5.5                                          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  1 Mt  -> mb ~ 6.25                                          "]], "Text",E\
xpressionUUID->"952121ca-65cd-49a3-b900-a4f42d7dfdcf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Cavity", " ", "decoupling", " ", "can", " ", "reduce", " ", "the", " ", 
   "observed", " ", "magnitude", " ", "by", " ", "up", " ", 
   RowBox[{"to", " ", "~", "1.5"}], " ", "units"}], ",", " ", 
  RowBox[{
   RowBox[{"making", " ", "small", " ", "tests", " ", "harder", " ", "to", " ", 
    RowBox[{"detect", " ", "--"}]}], "-", " ", 
   RowBox[{
   "but", " ", "requires", " ", "impractically", " ", "large", " ", 
    "cavities", " ", "for", " ", "yields", " ", "above", " ", "a", " ", "few",
     " ", 
    RowBox[{"kilotons", "."}]}]}]}]], "Text",ExpressionUUID->"1252b5d2-2b25-\
4bd8-95d1-26276062a6c5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8.3 Source physics differences", "Subsection",ExpressionUUID->"ba4339ab-f376-4a06-9a67-4a91ac260dc7"],

Cell[BoxData[
 RowBox[{"The", " ", "fundamental", " ", "difference", " ", "between", " ", 
  "an", " ", "earthquake", " ", "and", " ", "a", " ", "nuclear", " ", 
  "explosion", " ", "as", " ", "seismic", " ", "sources", " ", "lies", " ", 
  "in", " ", "their", " ", "source", " ", 
  RowBox[{"mechanism", ":"}]}]], "Text",ExpressionUUID->"df8e02ed-f91c-4fd7-\
84fe-4924f67cc8fa"],

Cell[BoxData[
 "Earthquake (double-couple / deviatoric source):\n" <> \
$CellContext`StringTrimRight[
  "  - Shear dislocation on a fault plane                        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Radiation pattern has four lobes (two compressional,      "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    two dilatational)                                         "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Efficient generation of S-waves and surface waves        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Surface wave magnitude Ms is large relative to mb        "]], "Text",Ex\
pressionUUID->"53f96822-9c29-43a1-a923-1c88490c111e"],

Cell[BoxData[
 "Nuclear explosion (isotropic source):\n" <> $CellContext`StringTrimRight[
  "  - Sudden expansion of a cavity (point source of pressure)   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Radiation pattern is spherically symmetric --- all        "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    first motions are compressional                           "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Very weak S-wave generation (only from interaction with   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    the free surface and pre-existing structure)              "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Surface wave magnitude Ms is small relative to mb        "]], "Text",Ex\
pressionUUID->"ea3b76f2-1018-4887-b3a7-6f64baf5e1d0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Plot", " ", "the", " ", "yield"}], "-", 
  RowBox[{
  "mb", " ", "scaling", " ", "relation", " ", "for", " ", "underground", " ", 
   "nuclear", " ", "tests"}]}]], "Text",ExpressionUUID->"0c0c5c31-5ec5-4432-\
b42e-6a1f9e7d06db"],

Cell["plotYieldMbRelation[]", "Input",ExpressionUUID->"9514cb6f-3be7-4f65-8e5c-66daf681df19"],

Cell[BoxData[
 RowBox[{"Display", " ", "the", " ", "North", " ", "Korean", " ", "nuclear", " ",
   "test", " ", "series", " ", "with", " ", "estimated", " ", "yields", " ", 
  "and", " ", "observed", " ", "magnitudes"}]], "Text",ExpressionUUID->\
"52f3afc0-6a79-491d-a9fd-8307d889d543"],

Cell["displayNKTestSeries[]", "Input",ExpressionUUID->"a12da7bf-44aa-43b7-9885-ffac6c9ef9ad"],

Cell[BoxData[
 RowBox[{"Side", "-", "by", "-", 
  RowBox[{
  "side", " ", "wavefront", " ", "snapshots", " ", "comparing", " ", 
   "earthquake", " ", "vs", " ", "nuclear", " ", "test", " ", "radiation", " ",
    "patterns"}]}]], "Text",ExpressionUUID->"dc459ada-9122-4fb1-a308-\
b4aa9e483b9a"],

Cell["plotEarthquakeVsNuclearSnapshots[]", "Input",ExpressionUUID->"52ff7761-1152-4f51-a47f-07de2de1c097"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["SECTION 9: EARTHQUAKE vs EXPLOSION DISCRIMINATION", "Section",ExpressionUUID->"672c70e7-6f6d-4e01-8ef5-e9342483af97"],

Cell[CellGroupData[{

Cell["9.1 The mb-Ms discrimination method", "Subsection",ExpressionUUID->"2cf99370-a43f-42af-9b58-941cef204b17"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "The", " ", "most", " ", "widely", " ", "used", " ", "seismic", " ", 
   "discriminant", " ", "between", " ", "earthquakes", " ", "and", " ", 
   "explosions", " ", "is", " ", "the", " ", 
   RowBox[{"mb", ":", 
    RowBox[{
     RowBox[{"Ms", " ", 
      RowBox[{"criterion", ".", " ", "Body"}]}], "-", 
     RowBox[{"wave", " ", "magnitude", " ", 
      RowBox[{"(", "mb", ")"}], " ", "is", " ", "measured", " ", "from", " ", 
      "short"}], "-", 
     RowBox[{"period", " ", "P"}], "-", 
     RowBox[{"waves", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"typically", " ", "~", "1"}], " ", "Hz"}], ")"}]}]}]}]}], ",",
   " ", 
  RowBox[{
   RowBox[{"while", " ", "surface"}], "-", 
   RowBox[{"wave", " ", "magnitude", " ", 
    RowBox[{"(", "Ms", ")"}], " ", "is", " ", "measured", " ", "from", " ", 
    "long"}], "-", 
   RowBox[{"period", " ", "Rayleigh", " ", "waves", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"~", "20"}], " ", "s", " ", "period"}], ")"}], 
     "."}]}]}]}]], "Text",ExpressionUUID->"5a264933-5387-4934-b73f-\
0889eabb71b0"],

Cell[BoxData[
 "For earthquakes, the efficient generation of surface waves means that Ms is \
large relative to mb. Empirically:\n" <> $CellContext`StringTrimRight[
  "  Earthquakes: Ms ~ 1.15 mb - 0.52  (Marshall & Basham 1972) "]], "Text",Ex\
pressionUUID->"73d7ffbb-d142-476a-a7b8-c4a9a172519e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"For", " ", "explosions"}], ",", " ", 
  RowBox[{
   RowBox[{
   "the", " ", "weak", " ", "surface", " ", "wave", " ", "generation", " ", 
    "means", " ", "that", " ", "Ms", " ", "is", " ", "systematically", " ", 
    "lower", " ", "for", " ", "the", " ", "same", " ", 
    RowBox[{"mb", ".", " ", "This"}], " ", "creates", " ", "a", " ", "clear", 
    " ", "separation", " ", "in", " ", "the", " ", "mb"}], "-", 
   RowBox[{"Ms", " ", 
    RowBox[{"plot", ":", " ", 
     RowBox[{
     "earthquakes", " ", "cluster", " ", "above", " ", "the", " ", 
      "discrimination", " ", "line"}]}]}]}], ",", " ", 
  RowBox[{"explosions", " ", 
   RowBox[{"below", "."}]}]}]], "Text",ExpressionUUID->"4a788d7b-489d-4690-\
8423-ec4ee3dec4d5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["9.2 Why the method works", "Subsection",ExpressionUUID->"2f1054c9-9090-4dab-a57a-43dcc556e49b"],

Cell[BoxData[
 "The physical basis is the source mechanism difference:\n" <> \
$CellContext`StringTrimRight[
  "  - Earthquakes (double-couple) efficiently excite Rayleigh   "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    waves because the shear dislocation has a strong          "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    vertical force component                                  "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "  - Explosions (isotropic) generate Rayleigh waves only       "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    through secondary mechanisms (spall, tectonic release)    "] <> 
 "\n" <> $CellContext`StringTrimRight[
  "    that are much weaker                                      "]], "Text",E\
xpressionUUID->"546e0d16-bace-4a70-bf06-2e5213361b31"],

Cell[BoxData[
 RowBox[{"The", " ", 
  RowBox[{"mb", ":", 
   RowBox[{
   "Ms", " ", "criterion", " ", "has", " ", "been", " ", "successfully", " ", 
    "applied", " ", "to", " ", "identify", " ", "all", " ", "confirmed", " ", 
    "nuclear", " ", "tests", " ", "since", " ", "the", " ", "1960", "s", " ", 
    "and", " ", "is", " ", "a", " ", "cornerstone", " ", "of", " ", "CTBT", " ", 
    RowBox[{"verification", ".", " ", "It"}], " ", "was", " ", "instrumental",
     " ", "in", " ", "confirming", " ", "the", " ", "North", " ", "Korean", " ",
     "tests", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2006", "-", "2017"}], ")"}], "."}]}]}]}]], "Text",ExpressionUUI\
D->"f389f139-c32e-430a-8465-8a69d058ae25"],


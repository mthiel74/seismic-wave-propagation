   RowBox[{"rock", "."}]}]}]], "Text",ExpressionUUID->"0e8b6427-04d9-4abc-\
a09c-af39cf615bc1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"At", " ", "convergent", " ", "boundaries", " ", 
   RowBox[{"(", 
    RowBox[{
    "subduction", " ", "zones", " ", "and", " ", "continental", " ", 
     "collision", " ", "zones"}], ")"}]}], ",", " ", 
  RowBox[{
   RowBox[{"plates", " ", "are", " ", "thrust", " ", 
    RowBox[{"together", " ", "--"}]}], "-", " ", 
   RowBox[{"producing", " ", "the", " ", 
    RowBox[{"world", "'"}], "s", " ", "largest", " ", "earthquakes", " ", 

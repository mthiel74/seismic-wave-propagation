 RowBox[{
  RowBox[{"Plot", " ", "the", " ", "mb"}], "-", 
  RowBox[{
  "Ms", " ", "discrimination", " ", "diagram", " ", "showing", " ", "clear", " ",
    "separation", " ", "between", " ", "earthquakes", " ", "and", " ", 
   "nuclear", " ", "tests"}]}]], "Text",ExpressionUUID->"0df7a6bd-14ad-4d4b-\
9a68-b18efa3d23b0"],


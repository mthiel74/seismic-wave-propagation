(*                                                              *)
(*   SECTION 10: GROUND MOTION VISUALIZATION --- THE HERO       *)
(*                                                              *)
(* ============================================================ *)
(* ============================================================ *)

(* ---- 10.1 What is a Ground Motion Visualization? ----         *)
(*                                                              *)
(* A Ground Motion Visualization (GMV) is a powerful technique   *)
(* for displaying seismic wave propagation as recorded by a      *)
(* network of seismometers. Developed and popularized by         *)
(* IRIS (Incorporated Research Institutions for Seismology,      *)
(* now part of EarthScope), GMVs have become one of the most     *)
(* compelling ways to communicate the physics of seismic waves   *)
(* to both specialists and the general public.                   *)
(*                                                              *)
(* In a GMV, each seismometer station is represented as a        *)
(* colored dot on a map. The color encodes the instantaneous     *)
(* ground displacement:                                          *)
(*   - Red indicates the ground is moving UP                     *)
(*   - Blue indicates the ground is moving DOWN                  *)
(*   - White/neutral indicates no displacement                   *)
(*   - Color intensity indicates amplitude                       *)
(*                                                              *)
(* As seismic waves sweep through the station network, the       *)
(* coherent wavefronts become visible as bands of alternating    *)
(* red and blue that propagate outward from the epicenter.       *)
(* The result is a direct, visceral visualization of the         *)
(* passage of seismic waves through the Earth --- the viewer     *)
(* literally watches the ground shake.                           *)
(*                                                              *)
(* ---- 10.2 How real GMVs are constructed ----                  *)
(*                                                              *)
(* The IRIS/EarthScope pipeline for producing GMVs involves      *)
(* several data processing steps:                                *)
(*                                                              *)
(* 1. Waveform retrieval: Download continuous seismogram data    *)
(*    from all available broadband stations in the region of     *)
(*    interest (typically hundreds to thousands of stations).    *)
(*    The vertical component (BHZ or LHZ channel) is used.       *)
(*                                                              *)
(* 2. Instrument response removal: Each seismometer has its      *)
(*    own frequency response. The instrument response is         *)
(*    deconvolved to convert from raw digital counts to true     *)
(*    ground displacement (in metres).                           *)
(*                                                              *)
(* 3. Bandpass filtering: The data is filtered to isolate the    *)
(*    frequency band of interest. For large earthquakes          *)
(*    (M >= 6.5), the typical IRIS band is 0.002-0.01 Hz         *)
(*    (periods of 100-500 seconds). This long-period band is    *)
(*    chosen because:                                            *)
(*      - It emphasizes the dominant surface waves               *)
(*      - Long-period waves are coherent over large distances    *)
(*      - Noise and local site effects are minimized             *)
(*      - The wavefronts are smooth and visually clear           *)
(*                                                              *)
(* 4. Per-station normalization: Each station's seismogram is    *)
(*    normalized independently to its own peak absolute          *)
(*    amplitude. This is the crucial step that makes GMVs work:  *)
(*    without normalization, stations near the epicenter would   *)
(*    dominate the display (their amplitudes are orders of       *)
(*    magnitude larger than distant stations), and the wave      *)
(*    passage at distant stations would be invisible. After      *)
(*    normalization, every station responds with comparable      *)
(*    visual intensity, making the wavefront coherent across     *)
(*    the entire network.                                        *)
(*                                                              *)
(* 5. Gain amplification: A gain factor (typically 5) is         *)
(*    applied after normalization. This means the color          *)
(*    saturates when the displacement exceeds 1/gain = 20%       *)
(*    of the station's peak amplitude. The gain makes weaker     *)
(*    arrivals (secondary phases, reflections) visible while     *)
(*    the dominant phases saturate to full color.                 *)
(*                                                              *)
(* 6. Color mapping: At each animation timestep, each station    *)
(*    dot is colored based on its normalized, amplified           *)
(*    displacement: the color ranges from saturated blue          *)
(*    (maximum negative displacement) through white (zero)       *)
(*    to saturated red (maximum positive displacement).          *)
(*                                                              *)
(* ---- 10.3 Our synthetic GMV ----                              *)
(*                                                              *)
(* Rather than downloading real waveform data (which would       *)
(* require significant data access and processing               *)
(* infrastructure), we construct a synthetic GMV from first      *)
(* principles. The key ingredients are:                          *)
(*                                                              *)
(* Station network: We generate a synthetic network of           *)
(* approximately 2000 stations distributed across Europe and     *)
(* the Mediterranean, matching the approximate station density   *)
(* of real European seismic networks (ORFEUS, GEOFON, etc.).    *)
(* Stations are placed preferentially on land areas using the    *)
(* GeoPosition framework.                                        *)
(*                                                              *)
(* Travel times: For each station, we compute the P-wave,        *)
(* S-wave, and Rayleigh wave arrival times using our PREM        *)
(* velocity model and the travel time curves derived in          *)
(* Section 4. The epicentral distance to each station is         *)
(* computed from the great-circle distance using the geodesic    *)
(* formula.                                                      *)
(*                                                              *)
(* Synthetic seismogram: At each station, we construct a         *)
(* synthetic ground displacement trace as the superposition of   *)
(* Ricker wavelets centered at the predicted arrival time of     *)
(* each phase (P, S, Rayleigh).                                  *)
(*                                                              *)
(* ---- 10.4 The Ricker wavelet ----                             *)
(*                                                              *)
(* The Ricker wavelet (also known as the "Mexican hat" wavelet)  *)
(* is a zero-phase wavelet widely used in exploration            *)
(* seismology and synthetic seismogram construction. It is the   *)
(* negative normalized second derivative of a Gaussian:          *)
(*                                                              *)
(*   psi(t) = (1 - 2 (Pi f0 t)^2) Exp[-(Pi f0 t)^2]            *)
(*                                                              *)
(* where f0 is the dominant (peak) frequency. Key properties:    *)
(*                                                              *)
(*   - Clean bipolar pulse: one central positive peak flanked    *)
(*     by two symmetric negative troughs                         *)
(*   - Zero mean (the wavelet integrates to zero)                *)
(*   - Compact support in both time and frequency domains        *)
(*   - The dominant frequency f0 controls the wavelet width:     *)
(*     larger f0 gives a narrower, higher-frequency pulse        *)
(*   - Peak frequency equals f0; bandwidth ~ f0                  *)
(*                                                              *)
(* We chose the Ricker wavelet over a simple sine burst or       *)
(* Gaussian pulse because:                                       *)
(*   - Its bipolar nature naturally produces the alternating     *)
(*     red-blue pattern characteristic of real GMVs              *)
(*   - It is finite-duration (unlike a sinusoid), avoiding       *)
(*     Moire artifacts from sustained oscillations               *)
(*   - It has a well-defined dominant frequency, allowing us     *)
(*     to match the IRIS filter band                             *)
(*                                                              *)
(* We use different dominant frequencies for each seismic phase, *)
(* reflecting their different frequency content:                  *)
(*                                                              *)
(*   P-wave:    f0 = 0.007 Hz  (dominant period ~ 143 s)         *)
(*   S-wave:    f0 = 0.005 Hz  (dominant period ~ 200 s)         *)
(*   Rayleigh:  f0 = 0.003 Hz  (dominant period ~ 333 s)         *)
(*                                                              *)
(* These frequencies fall within the IRIS long-period filter      *)
(* band (0.002-0.01 Hz) used for M >= 6.5 earthquakes, ensuring *)
(* that our synthetic GMV has a realistic visual appearance.      *)
(*                                                              *)
(* ---- 10.5 Per-station normalization ----                      *)
(*                                                              *)
(* Following the IRIS methodology, we normalize each station's   *)
(* synthetic seismogram independently to its own peak absolute   *)
(* amplitude:                                                    *)
(*                                                              *)
(*   u_norm(t) = gain * u(t) / Max[Abs[u(t)]]                   *)
(*                                                              *)
(* where gain = 5 (the IRIS standard). After normalization:      *)
(*                                                              *)
(*   - Every station's peak displacement maps to the same color  *)
(*     intensity, regardless of distance from the epicenter      *)
(*   - The gain factor of 5 means the color saturates at         *)
(*     1/5 = 20% of peak amplitude                               *)
(*   - This makes weaker arrivals clearly visible: P-waves       *)
(*     typically saturate even though they are much weaker than  *)
(*     the Rayleigh wave that dominates the raw trace            *)
(*   - The result is a display where P, S, and Rayleigh wave     *)
(*     fronts are all visible as they sweep across the network   *)
(*                                                              *)
(* This normalization is the key to why GMVs are so effective    *)
(* as visualizations: it compensates for geometric spreading     *)
(* and makes the wave passage visible across the entire          *)
(* network extent.                                               *)
(*                                                              *)
(* ---- 10.6 Generating the GMV ----                             *)
(*                                                              *)
(* We now generate the Ground Motion Visualization for the       *)
(* 2025 Myanmar Mw 7.7 earthquake, as observed across a         *)
(* synthetic European station network. The earthquake            *)
(* epicenter is at 21.88 N, 96.01 E. The P-wave arrives at      *)
(* European stations after approximately 600-900 seconds, with   *)
(* the S-wave following ~400 seconds later and the Rayleigh      *)
(* wave arriving last.                                           *)
(*                                                              *)
(* This is the culmination of everything we have built in this   *)
(* notebook: the PREM velocity model determines the wave         *)
(* speeds, the ray theory gives the travel times, the Ricker     *)
(* wavelet shapes the pulse, and the per-station normalization   *)
(* makes it all visible. The result is a simulation that         *)
(* closely resembles the real IRIS GMVs --- built entirely       *)
(* from first principles.                                        *)

(* Generate the European station network *)
(* ~2000 stations distributed across Europe, Mediterranean, *)
(* and western Asia, preferentially on land *)
stations = generateEuropeanStations[2000];

(* Define the time array for the simulation *)
(* From 250 s to 2800 s in steps of 3.4 s -> ~750 frames *)
tArray = Range[250, 2800, 3.4];

(* Myanmar earthquake epicenter coordinates *)
(* (epicenterLat = 21.88, epicenterLon = 96.01) *)

(* Compute synthetic seismograms for all stations *)
(* Each seismogram is the superposition of Ricker wavelets *)
(* for P, S, and Rayleigh arrivals at the appropriate travel times *)
(* NOTE: This computation takes several minutes for ~2000 stations *)
seismograms = Table[
  syntheticSeismogramGMV[
    geodesicDistanceDeg[21.88, 96.01, stations[[i, 1]], stations[[i, 2]]],
    tArray
  ],
  {i, Length[stations]}
];

(* Per-station normalization with IRIS gain factor = 5 *)
(* Each station's trace is divided by its own peak absolute *)
(* amplitude, then multiplied by the gain *)
normalizedSeis = normalizePerStation[seismograms, 5];

(* Find a reference station at approximately 55 degrees epicentral *)
(* distance --- this station's seismogram will be plotted in the *)
(* lower panel of the GMV display *)
distances = Table[
  geodesicDistanceDeg[21.88, 96.01, stations[[i, 1]], stations[[i, 2]]],
  {i, Length[stations]}
];
refIdx = First[Ordering[Abs[distances - 55], 1]];

(* Interactive Ground Motion Visualization *)
(* The Manipulate slider controls the elapsed time since the *)
(* earthquake origin. The map shows station colors encoding *)
(* instantaneous ground displacement. Below the map, the *)
(* reference station seismogram is displayed with a time marker. *)
Manipulate[
  gmvFrame[t, stations, normalizedSeis, tArray,
    earthquakeCatalog[[1]], refIdx],
  {{t, 250, "Time after origin (s)"}, 250, 2800, 1,
    Appearance -> "Labeled", AnimationRate -> 3}
]

